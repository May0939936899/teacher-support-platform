# === Dev Mode ===
# Set to 'true' for local development to bypass Google login
# NEVER set this in production (Vercel)
# NEXT_PUBLIC_DEV_MODE=true

# === Supabase ===
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...your-anon-key

# Server-side only (DO NOT prefix with NEXT_PUBLIC_)
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key

# === Gemini AI (server-side only) ===
GEMINI_API_KEY=AIza...your-gemini-api-key

# === Admin Control ===
# Comma-separated list of email addresses that have admin access
ADMIN_EMAILS=admin@example.com
